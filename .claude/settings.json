{
  "permissions": {
    "allow": [
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npx tsc*)",
      "Bash(npx vitest*)",
      "Bash(npx playwright*)",
      "Bash(npx prettier*)",
      "Bash(npx eslint*)",
      "Bash(npx next *)",
      "Bash(node *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git merge*)",
      "Bash(git stash*)",
      "Bash(git rebase*)",
      "Bash(git remote*)",
      "Bash(git show*)",
      "Bash(git tag*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr create*)",
      "Bash(gh pr comment*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue create*)",
      "Bash(gh api *)",
      "Bash(gh status*)",
      "Bash(gh auth status*)",
      "Bash(gh repo view*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(terraform init*)",
      "Bash(terraform plan*)",
      "Bash(terraform validate*)",
      "Bash(terraform fmt*)",
      "Bash(terraform show*)",
      "Bash(terraform output*)",
      "Bash(terraform state list*)",
      "Bash(terraform state show*)",
      "Bash(az account *)",
      "Bash(az group show*)",
      "Bash(az group list*)",
      "Bash(az webapp show*)",
      "Bash(az webapp list*)",
      "Bash(az functionapp show*)",
      "Bash(az functionapp list*)",
      "Bash(az storage account show*)",
      "Bash(az storage account list*)",
      "Bash(az keyvault show*)",
      "Bash(az keyvault list*)",
      "Bash(docker build*)",
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(docker compose ps*)",
      "Bash(python -m pytest*)",
      "Bash(pip install*)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(wc *)",
      "Bash(which *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- .)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(git branch -D *)",
      "Bash(terraform destroy*)",
      "Bash(terraform apply*)",
      "Bash(az group delete*)",
      "Bash(az resource delete*)",
      "Bash(az webapp delete*)",
      "Bash(az functionapp delete*)",
      "Bash(az keyvault delete*)",
      "Bash(gh repo delete*)",
      "Bash(gh pr close*)",
      "Bash(gh issue close*)",
      "Bash(gh secret *)",
      "Bash(npm publish*)"
    ]
  },

  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/protect-sensitive.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-destructive-bash.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/warn-uncommitted.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-build-check.sh",
            "timeout": 120
          }
        ]
      }
    ]
  },

  "env": {
    "NODE_ENV": "development",
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}
