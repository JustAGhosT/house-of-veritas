{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "env": {}
    },
    "storybook": {
      "command": "npx",
      "args": ["-y", "storybook-mcp-server"],
      "env": {
        "STORYBOOK_URL": "http://localhost:6006",
        "OUTPUT_DIR": "./storybook-screenshots",
        "LOG_LEVEL": "info"
      }
    }
  }
}
